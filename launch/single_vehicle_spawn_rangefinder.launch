<?xml version="1.0"?>
<launch>
    <!-- Spawn one PX4 SITL vehicle from a local SDF Jinja template. -->

    <arg name="x" default="0"/>
    <arg name="y" default="0"/>
    <arg name="z" default="0"/>
    <arg name="R" default="0"/>
    <arg name="P" default="0"/>
    <arg name="Y" default="0"/>

    <arg name="vehicle" default="iris_hrlv_ez4"/>
    <arg name="model_sdf" default="$(find aofe_star)/models/iris_hrlv_ez4/iris_hrlv_ez4.sdf.jinja"/>
    <arg name="px4_sim_model" default="gazebo-classic_iris"/>
    <arg name="ID" default="1"/>
    <env name="PX4_SIM_MODEL" value="$(arg px4_sim_model)"/>

    <arg name="mavlink_udp_port" default="14560"/>
    <arg name="mavlink_tcp_port" default="4560"/>
    <arg name="gst_udp_port" default="5600"/>
    <arg name="video_uri" default="5600"/>
    <arg name="mavlink_cam_udp_port" default="14530"/>
    <arg name="mavlink_id" value="$(eval 1 + arg('ID'))"/>

    <arg name="interactive" default="true"/>
    <arg unless="$(arg interactive)" name="px4_command_arg1" value=""/>
    <arg     if="$(arg interactive)" name="px4_command_arg1" value="-d"/>

    <arg name="cmd" default="$(find mavlink_sitl_gazebo)/scripts/jinja_gen.py --stdout --mavlink_id=$(arg mavlink_id) --mavlink_udp_port=$(arg mavlink_udp_port) --mavlink_tcp_port=$(arg mavlink_tcp_port) --gst_udp_port=$(arg gst_udp_port) --video_uri=$(arg video_uri) --mavlink_cam_udp_port=$(arg mavlink_cam_udp_port) $(arg model_sdf) $(find aofe_star)"/>
    <param command="$(arg cmd)" name="sdf_$(arg vehicle)$(arg ID)"/>

    <node name="sitl_$(arg ID)"
          pkg="px4"
          type="px4"
          output="screen"
          args="$(find px4)/build/px4_sitl_default/etc -s etc/init.d-posix/rcS -i $(arg ID) -w sitl_$(arg vehicle)_$(arg ID) $(arg px4_command_arg1)">
    </node>

    <node name="$(anon vehicle_spawn)"
          pkg="gazebo_ros"
          type="spawn_model"
          output="screen"
          args="-sdf -param sdf_$(arg vehicle)$(arg ID) -model $(arg vehicle)_$(arg ID) -x $(arg x) -y $(arg y) -z $(arg z) -R $(arg R) -P $(arg P) -Y $(arg Y)"/>
</launch>
